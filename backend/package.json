{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express backend for Gym Management System",
  "main": "src/app.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --watch 'src/**/*.js' src/app.js",
    "start": "node src/app.js",
    "lint": "eslint 'src/**/*.js'",
    "format": "prettier --write 'src/**/*.js'",
    "migrate": "sequelize-cli db:migrate --config src/config/sequelize-cli.js",
    "migrate:undo": "sequelize-cli db:migrate:undo --config src/config/sequelize-cli.js",
    "seed": "sequelize-cli db:seed:all --config src/config/sequelize-cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.842.0",
    "@supabase/supabase-js": "^2.89.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "chart.js": "^4.5.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.14.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.1.1",
    "nodemailer": "^7.0.12",
    "path": "^0.12.7",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.1",
    "twilio": "^5.7.2",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/multer": "^1.4.13",
    "cross-env": "^7.0.3",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-import": "^2.27.5",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0",
    "sequelize-cli": "^6.6.3"
  }
}